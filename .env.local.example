# Copy to .env.local and fill in. NEVER commit .env.local.

# From Supabase Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://termxngysvotnfbzbgrv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — server-only. Used for the platform-operator pages and
# admin RPC calls that need to bypass RLS. NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Where the owner portal lives (used in invitation emails + Stripe return URLs)
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000

# Stripe (server-only). The secret key is used by the checkout Server Action
# to create Checkout Sessions. The edge function uses its own copy of this.
STRIPE_SECRET_KEY=sk_test_...

# Publishable key (browser-safe) — only needed if you embed Stripe Elements later.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
